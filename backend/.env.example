# Harven.AI Backend - Environment Configuration
# Copy to .env and fill with your values

# ============================================
# DATABASE — Supabase PostgreSQL (REQUIRED)
# ============================================
# Option 1: Direct connection string (preferred)
DATABASE_URL=postgresql://postgres.YOURREF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Option 2: Auto-construct from Supabase components
# SUPABASE_URL=https://YOURREF.supabase.co
# SUPABASE_DB_PASSWORD=your-db-password

# Option 3: Local dev with SQLite
# USE_SQLITE=true

# ============================================
# OPENAI (AI Agents) — REQUIRED FOR AI
# ============================================
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ============================================
# AUTHENTICATION
# ============================================
# JWT secret — uses fallback chain: JWT_SECRET_KEY > JWT_SECRET > SUPABASE_KEY
JWT_SECRET_KEY=super-secret-jwt-key
JWT_EXPIRATION_HOURS=8

# Supabase anon key (used as JWT fallback if JWT_SECRET_KEY not set)
# SUPABASE_KEY=eyJ...

# ============================================
# PRODUCTION (Deploy)
# ============================================
ENVIRONMENT=development

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:3000

# Server port (default: 8000)
PORT=8000

# ============================================
# JACAD - Academic System (Integration)
# ============================================
# JACAD_URL=https://jacad.escola.com.br/api
# JACAD_API_KEY=your-jacad-api-key

# ============================================
# MOODLE LMS (Bidirectional Integration)
# ============================================
# MOODLE_URL=https://moodle.escola.com.br
# MOODLE_TOKEN=your-moodle-token
# MOODLE_WEBHOOK_SECRET=secret-for-webhook-validation

# ============================================
# LTI 1.1 - MOODLE EXTERNAL TOOL
# ============================================
# LTI_ENABLED=true
# LTI_CONSUMER_KEY=harven-lti-xxxx
# LTI_SHARED_SECRET=your-generated-secret
# LTI_AUTO_CREATE_USERS=true
# LTI_REDIRECT_URL=https://harven.escola.com.br

# ============================================
# EMAIL (Optional Notifications)
# ============================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ============================================
# ELEVENLABS (Text-to-Speech - Optional)
# ============================================
# ELEVENLABS_API_KEY=sk-your-elevenlabs-key

# ============================================
# AI COST CONTROL (Optional)
# ============================================
# AI_DAILY_TOKEN_LIMIT=500000
